---
---

<section class="section newsletter">
  <div class="container-narrow">
    <div class="newsletter__card reveal">
      <div class="newsletter__content">
        <span class="eyebrow eyebrow--blue">FREE · WEEKLY</span>
        <h2>The Remodel Intel Briefing.</h2>
        <p>
          Every Sunday, one email. A real-world remodel red flag, a material trend worth
          watching, or a contractor move to be aware of. No fluff. No pitches.
          Unsubscribe whenever.
        </p>
      </div>

      <form
        class="newsletter__form"
        id="nl-form"
        action="https://services.leadconnectorhq.com/hooks/wpTQy7qdVH6nVVcMvR8R/8c18c2b6-c3ba-4add-8678-9f398af7b7a7"
        method="post"
        novalidate
      >
        <label for="nl-email" class="sr-only">Your email</label>
        <input
          id="nl-email"
          type="email"
          name="email"
          placeholder="your@email.com"
          required
          autocomplete="email"
        />
        <button type="submit" class="btn btn--primary" id="nl-submit">
          Subscribe
        </button>
      </form>
      <p class="newsletter__disclaimer" id="nl-status">
        We respect your inbox. One email a week, tops. Unsubscribe with one click.
      </p>
    </div>
  </div>
</section>

<style>
  .newsletter { padding-top: 0; padding-bottom: clamp(3rem, 5vw, 5rem); background: var(--gtw-white); }
  .newsletter__card {
    background: linear-gradient(135deg, #F7F8FA 0%, #EFF2F8 100%);
    border-radius: var(--radius-xl);
    padding: clamp(2rem, 4vw, 3.5rem);
    border: 1px solid var(--border-subtle);
    position: relative;
    overflow: hidden;
  }
  .newsletter__card::before {
    content: '';
    position: absolute;
    top: -120px;
    right: -120px;
    width: 280px;
    height: 280px;
    background: radial-gradient(circle, rgba(28, 81, 155, 0.12) 0%, transparent 70%);
    border-radius: 50%;
  }
  .newsletter__content {
    position: relative;
    text-align: center;
    max-width: 520px;
    margin: 0 auto 2rem;
  }
  .newsletter__content h2 {
    color: var(--gtw-blue);
    margin-bottom: 0.75rem;
  }
  .newsletter__content p {
    color: var(--text-secondary);
    font-size: 1.02rem;
    margin: 0;
    line-height: 1.6;
  }
  .newsletter__form {
    position: relative;
    display: flex;
    gap: 0.6rem;
    max-width: 520px;
    margin: 0 auto;
  }
  .newsletter__form input {
    flex: 1;
    padding: 16px 18px;
    border: 1.5px solid var(--border-subtle);
    border-radius: var(--radius-sm);
    font-family: var(--font-body);
    font-size: 0.98rem;
    background: var(--gtw-white);
    color: var(--gtw-dark);
    transition: border-color var(--t-fast), box-shadow var(--t-fast);
  }
  .newsletter__form input:focus {
    outline: none;
    border-color: var(--gtw-blue);
    box-shadow: 0 0 0 4px rgba(28, 81, 155, 0.1);
  }
  .newsletter__form .btn {
    padding: 16px 28px;
  }
  .newsletter__disclaimer {
    position: relative;
    text-align: center;
    font-size: 0.82rem;
    color: var(--text-muted);
    margin: 1rem 0 0;
  }

  @media (max-width: 560px) {
    .newsletter__form { flex-direction: column; }
    .newsletter__form .btn { width: 100%; }
  }

  .newsletter__form.is-submitted { display: none; }
  .newsletter__success {
    display: none;
    text-align: center;
    color: var(--gtw-blue);
    font-weight: 600;
    font-size: 1.05rem;
    padding: 1rem 0;
  }
  .newsletter__success.is-visible { display: block; }
  #nl-status.is-error { color: #c0392b; font-weight: 600; }
</style>

<script is:inline>
  (function () {
    const form = document.getElementById('nl-form');
    if (!form) return;
    const status = document.getElementById('nl-status');
    const submitBtn = document.getElementById('nl-submit');
    const defaultText = status ? status.textContent : '';
    const successHtml = "Thanks — you're in. Watch for the next briefing on Sunday.";

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const email = form.querySelector('#nl-email').value.trim();
      if (!email) return;

      submitBtn.disabled = true;
      submitBtn.textContent = 'Subscribing…';
      status.classList.remove('is-error');
      status.textContent = defaultText;

      try {
        const res = await fetch(form.action, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email: email, source: 'newsletter_form' }),
        });

        if (!res.ok) throw new Error('HTTP ' + res.status);

        if (typeof gtag === 'function') {
          gtag('event', 'newsletter_signup', { source: 'newsletter_form' });
        }

        form.classList.add('is-submitted');
        status.textContent = successHtml;
        status.classList.remove('is-error');
      } catch (err) {
        submitBtn.disabled = false;
        submitBtn.textContent = 'Subscribe';
        status.textContent = "Something went wrong. Try again, or email roy@getthewolf.info.";
        status.classList.add('is-error');
      }
    });
  })();
</script>
