---
import { FAQ } from '../data/site';
---

<section class="section faq" id="faq">
  <div class="container-narrow">
    <div class="section-header reveal">
      <span class="eyebrow">QUESTIONS?</span>
      <h2>Answers, straight up.</h2>
      <p class="lead">
        Didn't find what you were looking for? Email us at
        <a href="mailto:info@getthewolf.info">info@getthewolf.info</a>
        — a real person answers every message.
      </p>
    </div>

    <div class="faq__list">
      {FAQ.map((item, i) => (
        <details class="faq__item reveal" open={i === 0}>
          <summary>
            <span class="faq__q">{item.q}</span>
            <span class="faq__toggle" aria-hidden="true">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
                <path d="M12 5v14M5 12h14" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" />
              </svg>
            </span>
          </summary>
          <div class="faq__a">
            <p>{item.a}</p>
          </div>
        </details>
      ))}
    </div>
  </div>
</section>

<style>
  .faq { background: var(--gtw-white); }
  .faq__list {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    max-width: 760px;
    margin: 0 auto;
  }
  .faq__item {
    background: var(--bg-alt);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius);
    padding: 0 1.5rem;
    transition: border-color var(--t-fast);
  }
  .faq__item[open] {
    border-color: var(--gtw-blue-support);
    background: var(--gtw-white);
    box-shadow: var(--shadow-sm);
  }
  .faq__item summary {
    padding: 1.25rem 0;
    cursor: pointer;
    list-style: none;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }
  .faq__item summary::-webkit-details-marker { display: none; }
  .faq__q {
    font-weight: 700;
    font-size: 1.05rem;
    color: var(--gtw-dark);
  }
  .faq__toggle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: var(--gtw-light-gray);
    color: var(--gtw-dark);
    flex-shrink: 0;
    transition: background var(--t-fast), transform var(--t-fast), color var(--t-fast);
  }
  .faq__item[open] .faq__toggle {
    background: var(--gtw-orange);
    color: var(--gtw-white);
    transform: rotate(45deg);
  }
  .faq__a {
    padding: 0 0 1.5rem;
    border-top: 1px solid var(--border-subtle);
    padding-top: 1rem;
  }
  .faq__a p {
    margin: 0;
    color: var(--text-secondary);
    font-size: 0.98rem;
    line-height: 1.6;
  }
</style>
