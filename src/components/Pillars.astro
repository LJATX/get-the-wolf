---
import { PILLARS } from '../data/site';

const icons: Record<string, string> = {
  shield: `<svg width="32" height="32" viewBox="0 0 24 24" fill="none"><path d="M12 2 4 6v6c0 5 3.5 9 8 10 4.5-1 8-5 8-10V6z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/><path d="m9 12 2 2 4-4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
  book: `<svg width="32" height="32" viewBox="0 0 24 24" fill="none"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/><path d="M8 7h8M8 11h8" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>`,
  chart: `<svg width="32" height="32" viewBox="0 0 24 24" fill="none"><path d="M3 3v18h18" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/><path d="m7 15 4-4 4 4 5-6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
};
---

<section class="section pillars">
  <div class="container">
    <div class="section-header reveal">
      <span class="eyebrow">BUILT ON THREE PILLARS</span>
      <h2>Protection. Information. Confidence.</h2>
      <p class="lead">
        Every lesson, checklist, and coaching call is built around the three things every
        homeowner needs before, during, and after the remodel.
      </p>
    </div>

    <div class="pillars__grid">
      {PILLARS.map((pillar, i) => (
        <article class={`pillar-card pillar-card--${i} reveal`}>
          <div class="pillar-card__badge">{String(i + 1).padStart(2, '0')}</div>
          <div class="pillar-card__icon" set:html={icons[pillar.icon]}></div>
          <h3>{pillar.title}</h3>
          <p class="pillar-card__headline">{pillar.headline}</p>
          <ul class="pillar-card__list">
            {pillar.bullets.map((b) => (
              <li>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                  <path d="m5 12 5 5 9-11" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                <span>{b}</span>
              </li>
            ))}
          </ul>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .pillars { background: var(--gtw-white); }
  .pillars__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }
  .pillar-card {
    position: relative;
    background: var(--gtw-white);
    border-radius: var(--radius-lg);
    padding: 2.5rem 2rem;
    border: 1px solid var(--border-subtle);
    transition: transform var(--t-med), box-shadow var(--t-med), border-color var(--t-med);
    overflow: hidden;
  }
  .pillar-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 4px;
    background: var(--gtw-blue);
    transform-origin: left;
    transform: scaleX(0);
    transition: transform 400ms cubic-bezier(0.65, 0, 0.35, 1);
  }
  .pillar-card:hover::before { transform: scaleX(1); }
  .pillar-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
    border-color: transparent;
  }
  .pillar-card--1::before { background: var(--gtw-orange); }
  .pillar-card--2::before { background: var(--gtw-blue-support); }

  .pillar-card__badge {
    position: absolute;
    top: 1.25rem;
    right: 1.5rem;
    font-family: var(--font-head);
    font-size: 2.6rem;
    font-weight: 500;
    color: var(--border-subtle);
    line-height: 1;
    letter-spacing: -0.04em;
  }
  .pillar-card__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 60px;
    height: 60px;
    background: rgba(28, 81, 155, 0.09);
    color: var(--gtw-blue);
    border-radius: var(--radius);
    margin-bottom: 1.5rem;
  }
  .pillar-card--1 .pillar-card__icon {
    background: rgba(252, 104, 54, 0.1);
    color: var(--gtw-orange);
  }
  .pillar-card--2 .pillar-card__icon {
    background: rgba(101, 153, 226, 0.15);
    color: var(--gtw-blue);
  }
  .pillar-card h3 {
    font-family: var(--font-head);
    font-size: 1.7rem;
    font-weight: 500;
    color: var(--gtw-blue);
    margin-bottom: 0.6rem;
    letter-spacing: -0.015em;
  }
  .pillar-card__headline {
    font-size: 1rem;
    font-weight: 600;
    color: var(--gtw-dark);
    line-height: 1.45;
    margin-bottom: 1.5rem;
  }
  .pillar-card__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
  }
  .pillar-card__list li {
    display: flex;
    align-items: flex-start;
    gap: 0.6rem;
    font-size: 0.93rem;
    color: var(--text-secondary);
    line-height: 1.5;
  }
  .pillar-card__list svg {
    color: var(--gtw-blue);
    flex-shrink: 0;
    margin-top: 4px;
  }
  .pillar-card--1 .pillar-card__list svg { color: var(--gtw-orange); }

  @media (max-width: 960px) {
    .pillars__grid { grid-template-columns: 1fr; }
  }
</style>
