---
import { PACKAGES, SITE } from '../data/site';
---

<section class="section pricing" id="pricing">
  <div class="container">
    <div class="section-header reveal">
      <span class="eyebrow">CHOOSE YOUR PATH</span>
      <h2>All in — or start small.</h2>
      <p class="lead">
        Most members start with All Access because the math is obvious. But if you only need
        help with one phase of your remodel, every module is also available individually.
        You can upgrade to All Access later and we'll credit every dollar you've spent.
      </p>
    </div>

    <div class="pricing__layout">
      <article class="pricing__featured reveal">
        <div class="pricing__featured-tag">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 2 15 8l7 1-5 5 1 7-6-3-6 3 1-7-5-5 7-1z"/>
          </svg>
          RECOMMENDED — BEST VALUE
        </div>
        <div class="pricing__featured-body">
          <div class="pricing__featured-left">
            <h3>All Access Academy</h3>
            <p class="pricing__featured-sub">The full library + Friday coaching + community + every bonus.</p>
            <ul class="pricing__list">
              <li><svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2 4 6v6c0 5 3.5 9 8 10 4.5-1 8-5 8-10V6zM9 12l2 2 4-4-1.4-1.4L11 11.2l-.6-.6z"/></svg> All 8 modules &amp; 40+ video lessons</li>
              <li><svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2 4 6v6c0 5 3.5 9 8 10 4.5-1 8-5 8-10V6zM9 12l2 2 4-4-1.4-1.4L11 11.2l-.6-.6z"/></svg> Every printable script, checklist &amp; template</li>
              <li><svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2 4 6v6c0 5 3.5 9 8 10 4.5-1 8-5 8-10V6zM9 12l2 2 4-4-1.4-1.4L11 11.2l-.6-.6z"/></svg> 1 year of weekly live coaching with Roy</li>
              <li><svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2 4 6v6c0 5 3.5 9 8 10 4.5-1 8-5 8-10V6zM9 12l2 2 4-4-1.4-1.4L11 11.2l-.6-.6z"/></svg> Private homeowner community access</li>
              <li><svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2 4 6v6c0 5 3.5 9 8 10 4.5-1 8-5 8-10V6zM9 12l2 2 4-4-1.4-1.4L11 11.2l-.6-.6z"/></svg> The Red Flag Checklist PDF</li>
              <li><svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2 4 6v6c0 5 3.5 9 8 10 4.5-1 8-5 8-10V6zM9 12l2 2 4-4-1.4-1.4L11 11.2l-.6-.6z"/></svg> Printable transcripts for every lesson</li>
              <li><svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2 4 6v6c0 5 3.5 9 8 10 4.5-1 8-5 8-10V6zM9 12l2 2 4-4-1.4-1.4L11 11.2l-.6-.6z"/></svg> Future content updates — forever</li>
            </ul>
          </div>
          <div class="pricing__featured-right">
            <div class="pricing__featured-price">
              <span class="pricing__featured-currency">$</span>
              <span class="pricing__featured-amount">{SITE.price}</span>
            </div>
            <p class="pricing__featured-note">One-time payment · Lifetime library access</p>
            <a href={SITE.checkoutUrl} class="btn btn--primary btn--xl btn--block">
              Get All Access
              <svg width="16" height="16" viewBox="0 0 20 20" fill="none"><path d="M4 10h12M12 6l4 4-4 4" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <div class="pricing__featured-trust">
              <span>&#x2713; Secure checkout</span>
              <span>&#x2713; Instant access</span>
            </div>
          </div>
        </div>
      </article>

      <div class="pricing__divider reveal">
        <span>Or start with one phase — every package is included inside All Access</span>
      </div>

      <div class="pricing__packages">
        {PACKAGES.map((pkg) => (
          <article class="pricing__card reveal">
            <h4>{pkg.name}</h4>
            <p class="pricing__card-tag">{pkg.tagline}</p>
            <div class="pricing__card-price">
              <span class="pricing__card-currency">$</span>
              <span class="pricing__card-amount">{pkg.price}</span>
            </div>
            <p class="pricing__card-note">One-time · Lifetime access to this package</p>
            <ul>
              {pkg.items.map((item) => (
                <li>
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="m5 12 5 5 9-11" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  {item}
                </li>
              ))}
            </ul>
            <a href={SITE.checkoutUrl} class="btn btn--secondary btn--block">
              Get {pkg.name}
            </a>
          </article>
        ))}
      </div>

      <p class="pricing__upsell reveal">
        <strong>Upgrade anytime.</strong> Buy a package today, decide you want All Access later?
        We credit 100% of what you paid. No catch.
      </p>
    </div>
  </div>
</section>

<style>
  .pricing { background: var(--bg-alt); }
  .pricing__layout {
    display: flex;
    flex-direction: column;
    gap: 3rem;
    max-width: 1100px;
    margin: 0 auto;
  }

  .pricing__featured {
    position: relative;
    background: var(--gtw-white);
    border-radius: var(--radius-xl);
    border: 2px solid var(--gtw-blue);
    overflow: hidden;
    box-shadow: 0 30px 80px -30px rgba(28, 81, 155, 0.35);
  }
  .pricing__featured-tag {
    background: var(--gtw-orange);
    color: var(--gtw-white);
    text-align: center;
    padding: 10px 20px;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
  }
  .pricing__featured-body {
    display: grid;
    grid-template-columns: 1.3fr 1fr;
    gap: 0;
  }
  .pricing__featured-left {
    padding: 2.5rem 2.5rem;
    border-right: 1px solid var(--border-subtle);
  }
  .pricing__featured-left h3 {
    font-family: var(--font-head);
    font-weight: 500;
    font-size: 2rem;
    color: var(--gtw-blue);
    margin-bottom: 0.5rem;
    letter-spacing: -0.02em;
  }
  .pricing__featured-sub {
    color: var(--text-secondary);
    margin-bottom: 1.5rem;
    font-size: 1.02rem;
  }
  .pricing__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
  }
  .pricing__list li {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    font-size: 0.96rem;
    color: var(--gtw-dark);
  }
  .pricing__list svg { color: var(--gtw-blue); flex-shrink: 0; }

  .pricing__featured-right {
    padding: 2.5rem 2.5rem;
    background: linear-gradient(180deg, #F7F8FA 0%, #EFF2F8 100%);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
  }
  .pricing__featured-price {
    display: flex;
    align-items: flex-start;
    justify-content: center;
    margin-bottom: 0.6rem;
  }
  .pricing__featured-currency {
    font-family: var(--font-head);
    font-weight: 500;
    font-size: 2rem;
    color: var(--gtw-orange);
    margin-top: 0.7rem;
  }
  .pricing__featured-amount {
    font-family: var(--font-head);
    font-weight: 500;
    font-size: clamp(4rem, 8vw, 6rem);
    color: var(--gtw-orange);
    line-height: 1;
    letter-spacing: -0.04em;
  }
  .pricing__featured-note {
    font-size: 0.88rem;
    color: var(--text-secondary);
    margin-bottom: 1.5rem;
  }
  .pricing__featured-trust {
    display: flex;
    gap: 1.5rem;
    margin-top: 1rem;
    font-size: 0.82rem;
    color: var(--text-muted);
  }

  .pricing__divider {
    text-align: center;
    position: relative;
  }
  .pricing__divider::before {
    content: '';
    position: absolute;
    top: 50%;
    left: 0;
    right: 0;
    height: 1px;
    background: var(--border-subtle);
  }
  .pricing__divider span {
    position: relative;
    background: var(--bg-alt);
    padding: 0 1.5rem;
    font-size: 0.88rem;
    color: var(--text-muted);
    font-weight: 600;
  }

  .pricing__packages {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }
  .pricing__card {
    background: var(--gtw-white);
    border-radius: var(--radius);
    padding: 2rem 1.75rem;
    border: 1px solid var(--border-subtle);
    display: flex;
    flex-direction: column;
    transition: transform var(--t-med), box-shadow var(--t-med);
  }
  .pricing__card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-md);
  }
  .pricing__card h4 {
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 1.15rem;
    color: var(--gtw-dark);
    margin-bottom: 0.3rem;
  }
  .pricing__card-tag {
    font-size: 0.85rem;
    color: var(--gtw-orange);
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin-bottom: 1.25rem;
  }
  .pricing__card-price {
    display: flex;
    align-items: flex-start;
    margin-bottom: 0.3rem;
  }
  .pricing__card-currency {
    font-family: var(--font-head);
    font-weight: 500;
    font-size: 1.4rem;
    color: var(--gtw-blue);
    margin-top: 0.5rem;
  }
  .pricing__card-amount {
    font-family: var(--font-head);
    font-weight: 500;
    font-size: 3.2rem;
    color: var(--gtw-blue);
    line-height: 1;
    letter-spacing: -0.03em;
  }
  .pricing__card-note {
    font-size: 0.82rem;
    color: var(--text-muted);
    margin-bottom: 1.5rem;
  }
  .pricing__card ul {
    list-style: none;
    padding: 0;
    margin: 0 0 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
    flex: 1;
  }
  .pricing__card ul li {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    font-size: 0.9rem;
    color: var(--gtw-dark);
  }
  .pricing__card ul svg { color: var(--gtw-blue); flex-shrink: 0; }

  .pricing__upsell {
    text-align: center;
    font-size: 0.95rem;
    color: var(--text-secondary);
    max-width: 620px;
    margin: 0 auto;
    padding: 1.25rem 1.5rem;
    background: var(--gtw-cream);
    border-radius: var(--radius);
    border: 1px solid rgba(252, 104, 54, 0.2);
  }
  .pricing__upsell strong { color: var(--gtw-dark); }

  @media (max-width: 900px) {
    .pricing__featured-body { grid-template-columns: 1fr; }
    .pricing__featured-left { border-right: 0; border-bottom: 1px solid var(--border-subtle); }
    .pricing__packages { grid-template-columns: 1fr; }
  }
</style>
