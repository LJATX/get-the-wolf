---
import { SITE } from '../data/site';
---

<section class="section final-cta" id="get-started">
  <div class="final-cta__bg" aria-hidden="true">
    <div class="final-cta__bg-image"></div>
    <div class="final-cta__bg-overlay"></div>
    <div class="final-cta__bg-pattern pattern-grid"></div>
  </div>

  <div class="container final-cta__container">
    <div class="reveal">
      <span class="eyebrow eyebrow--light">DON'T LEAVE YOUR REMODEL TO CHANCE</span>
      <h2 class="final-cta__headline">
        Every call you take before watching this course<br />
        could be <span class="final-cta__highlight">costing you thousands.</span>
      </h2>
      <p class="final-cta__sub">
        You're already going to spend six figures on this remodel. The real question is
        whether you'll spend it <em>well</em>. $297 today. Lifetime access. Next Friday's
        live coaching with Roy is already on the calendar.
      </p>

      <div class="final-cta__actions">
        <a href={SITE.checkoutUrl} class="btn btn--primary btn--xl">
          Get All Access — ${SITE.price}
          <svg width="18" height="18" viewBox="0 0 20 20" fill="none" aria-hidden="true">
            <path d="M4 10h12M12 6l4 4-4 4" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </a>
        <a href="#pricing" class="btn btn--secondary-light btn--lg">View Individual Packages</a>
      </div>

      <div class="final-cta__strip">
        <div class="final-cta__strip-item">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M12 22s8-4 8-12V5l-8-3-8 3v5c0 8 8 12 8 12z" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/><path d="m9 12 2 2 4-4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          <span>One-time $297 · Lifetime access</span>
        </div>
        <div class="final-cta__strip-item">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><rect x="3" y="5" width="18" height="16" rx="2" stroke="currentColor" stroke-width="2"/><path d="M3 9h18M8 3v4M16 3v4" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
          <span>Next live call: this Friday</span>
        </div>
        <div class="final-cta__strip-item">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M12 11a4 4 0 1 0 0-8 4 4 0 0 0 0 8zM6 21v-2a4 4 0 0 1 4-4h4a4 4 0 0 1 4 4v2" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          <span>Real person, real answer &lt; 24hrs</span>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .final-cta {
    position: relative;
    color: var(--gtw-white);
    overflow: hidden;
  }
  .final-cta__bg { position: absolute; inset: 0; }
  .final-cta__bg-image {
    position: absolute;
    inset: 0;
    background-image: url('/assets/imagery/kitchen-renovation-hero.jpg');
    background-size: cover;
    background-position: center;
    filter: brightness(0.35);
  }
  .final-cta__bg-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(28, 81, 155, 0.88) 0%, rgba(20, 64, 122, 0.95) 50%, rgba(14, 46, 91, 0.92) 100%);
  }
  .final-cta__bg-pattern { position: absolute; inset: 0; opacity: 0.5; }

  .final-cta__container {
    position: relative;
    z-index: 1;
    text-align: center;
    max-width: 820px;
    padding-top: 2rem;
    padding-bottom: 2rem;
  }

  .final-cta__headline {
    color: var(--gtw-white);
    font-size: clamp(2rem, 4vw, 3.2rem);
    margin: 1rem 0 1.25rem;
    line-height: 1.12;
  }
  .final-cta__highlight {
    color: var(--gtw-orange);
    font-style: italic;
    font-weight: 500;
  }
  .final-cta__sub {
    color: rgba(255, 255, 255, 0.78);
    font-size: 1.1rem;
    line-height: 1.6;
    margin-bottom: 2.5rem;
    max-width: 640px;
    margin-left: auto;
    margin-right: auto;
  }
  .final-cta__sub em { color: var(--gtw-white); font-style: italic; font-weight: 500; }

  .final-cta__actions {
    display: flex;
    justify-content: center;
    gap: 0.9rem;
    flex-wrap: wrap;
    margin-bottom: 2.5rem;
  }

  .final-cta__strip {
    display: flex;
    gap: 2rem;
    justify-content: center;
    flex-wrap: wrap;
    padding-top: 1.5rem;
    border-top: 1px solid rgba(255, 255, 255, 0.12);
  }
  .final-cta__strip-item {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.88rem;
    color: rgba(255, 255, 255, 0.82);
  }
  .final-cta__strip-item svg { color: var(--gtw-orange); }
</style>
