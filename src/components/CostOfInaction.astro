---
import { PAIN_POINTS } from '../data/site';

const icons: Record<string, string> = {
  search: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none"><circle cx="11" cy="11" r="7" stroke="currentColor" stroke-width="2"/><path d="m21 21-4.35-4.35" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>`,
  wallet: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none"><path d="M21 12V7H5a2 2 0 0 1 0-4h14v4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/><path d="M3 5v14a2 2 0 0 0 2 2h16v-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/><path d="M18 12a2 2 0 0 0 0 4h3v-4z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
  document: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/><path d="M14 2v6h6M8 13h8M8 17h8M8 9h1" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>`,
  home: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/><path d="M9 22V12h6v10" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/></svg>`,
};
---

<section class="section problem" id="problem">
  <div class="container">
    <div class="section-header reveal">
      <span class="eyebrow">SOUND FAMILIAR?</span>
      <h2>
        Every meeting you take before watching this course<br />
        <em class="problem__italic">could be costing you thousands.</em>
      </h2>
      <p class="lead">
        You're spending five to six figures on one of the biggest projects of your adult life.
        You've never done this before. And everyone in the room knows more than you.
        That's not a fair fight.
      </p>
    </div>

    <div class="grid grid--4 problem__grid">
      {PAIN_POINTS.map((point) => (
        <div class="problem__card reveal">
          <div class="problem__icon" set:html={icons[point.icon]}></div>
          <h3>{point.title}</h3>
          <p>{point.desc}</p>
        </div>
      ))}
    </div>

    <div class="problem__math reveal">
      <div class="problem__math-inner">
        <div class="problem__math-col">
          <div class="problem__math-label">The average $100k remodel</div>
          <div class="problem__math-stat">
            goes <strong>22%</strong> over budget
          </div>
          <div class="problem__math-detail">That's $22,000 you didn't plan to spend.</div>
        </div>
        <div class="problem__math-divider" aria-hidden="true"></div>
        <div class="problem__math-col">
          <div class="problem__math-label">The cost of this course</div>
          <div class="problem__math-stat problem__math-stat--accent">
            <strong>$297</strong>
          </div>
          <div class="problem__math-detail">You do the math.</div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .problem { background: var(--bg-alt); }
  .problem__italic {
    font-style: italic;
    color: var(--gtw-orange);
    font-weight: 500;
  }
  .problem__grid {
    gap: 1.25rem;
    margin-bottom: 4rem;
  }
  .problem__card {
    background: var(--gtw-white);
    border-radius: var(--radius);
    padding: 1.75rem 1.5rem;
    border: 1px solid var(--border-subtle);
    border-top: 3px solid var(--gtw-orange);
    transition: transform var(--t-med), box-shadow var(--t-med);
  }
  .problem__card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-md);
  }
  .problem__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: var(--radius-sm);
    background: rgba(252, 104, 54, 0.1);
    color: var(--gtw-orange);
    margin-bottom: 1.1rem;
  }
  .problem__card h3 {
    font-size: 1.1rem;
    font-weight: 700;
    margin-bottom: 0.6rem;
  }
  .problem__card p {
    font-size: 0.94rem;
    color: var(--text-secondary);
    line-height: 1.55;
    margin: 0;
  }

  .problem__math {
    background: var(--gtw-white);
    border-radius: var(--radius-lg);
    border: 1px solid var(--border-subtle);
    box-shadow: var(--shadow-md);
    max-width: 780px;
    margin: 0 auto;
    padding: 2.5rem 2rem;
  }
  .problem__math-inner {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: 2rem;
    align-items: center;
  }
  .problem__math-col { text-align: center; }
  .problem__math-label {
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 0.6rem;
  }
  .problem__math-stat {
    font-family: var(--font-head);
    font-weight: 500;
    font-size: clamp(1.4rem, 2.4vw, 1.85rem);
    color: var(--gtw-dark);
    letter-spacing: -0.02em;
    line-height: 1.15;
    margin-bottom: 0.5rem;
  }
  .problem__math-stat strong { color: var(--gtw-blue); font-weight: 500; }
  .problem__math-stat--accent strong { color: var(--gtw-orange); font-size: 2.5rem; }
  .problem__math-detail { font-size: 0.92rem; color: var(--text-secondary); }
  .problem__math-divider {
    width: 1px;
    height: 80px;
    background: var(--border-subtle);
  }

  @media (max-width: 700px) {
    .problem__math-inner {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
    .problem__math-divider {
      width: 80px;
      height: 1px;
      margin: 0 auto;
    }
  }
</style>
