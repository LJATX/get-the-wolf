---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import CostOfInaction from '../components/CostOfInaction.astro';
import Solution from '../components/Solution.astro';
import Pillars from '../components/Pillars.astro';
import Curriculum from '../components/Curriculum.astro';
import MeetRoy from '../components/MeetRoy.astro';
import ValueStack from '../components/ValueStack.astro';
import Pricing from '../components/Pricing.astro';
import Testimonials from '../components/Testimonials.astro';
import WhoFor from '../components/WhoFor.astro';
import FAQ from '../components/FAQ.astro';
import FinalCta from '../components/FinalCta.astro';
import Newsletter from '../components/Newsletter.astro';
import Footer from '../components/Footer.astro';
---

<Base>
  <Header />
  <main id="main">
    <Hero />
    <CostOfInaction />
    <Solution />
    <Pillars />
    <Curriculum />
    <MeetRoy />
    <ValueStack />
    <Pricing />
    <Testimonials />
    <WhoFor />
    <FAQ />
    <FinalCta />
    <Newsletter />
  </main>
  <Footer />
</Base>
