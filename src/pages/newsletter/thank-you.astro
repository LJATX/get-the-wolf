---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
---

<Base
  title="You're In — Get the Wolf"
  description="Thanks for subscribing to the Remodel Intel Briefing. Watch your inbox for your free welcome gift."
>
  <Header />
  <main id="main">
    <section class="thanks">
      <div class="thanks__bg" aria-hidden="true">
        <div class="thanks__bg-image"></div>
        <div class="thanks__bg-overlay"></div>
        <div class="thanks__bg-pattern pattern-grid"></div>
      </div>

      <div class="container thanks__container">
        <div class="thanks__card">
          <div class="thanks__check" aria-hidden="true">
            <svg width="40" height="40" viewBox="0 0 24 24" fill="none">
              <circle cx="12" cy="12" r="11" stroke="currentColor" stroke-width="1.5" />
              <path d="m7 12 3.5 3.5L17 9" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </div>

          <span class="eyebrow eyebrow--light">YOU'RE ON THE LIST</span>
          <h1 class="thanks__headline">
            Thanks for subscribing to the newsletter.
          </h1>
          <p class="thanks__lede">
            Look for your free welcome gift in your inbox.
          </p>

          <div class="thanks__divider" aria-hidden="true"></div>

          <p class="thanks__small">
            Every Sunday, you'll get one short email — a real-world remodel red flag, a
            material trend worth watching, or a contractor move to know about. No fluff.
            Unsubscribe with one click whenever you want.
          </p>

          <div class="thanks__actions">
            <a href="/" class="btn btn--secondary-light btn--lg">Back to the homepage</a>
            <a href="/#pricing" class="btn btn--primary btn--lg">
              See the Academy
              <svg width="18" height="18" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                <path d="M4 10h12M12 6l4 4-4 4" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Base>

<style>
  .thanks {
    position: relative;
    min-height: calc(100vh - 200px);
    display: flex;
    align-items: center;
    color: var(--gtw-white);
    overflow: hidden;
    padding: clamp(3rem, 8vw, 6rem) 0;
  }

  .thanks__bg { position: absolute; inset: 0; }
  .thanks__bg-image {
    position: absolute;
    inset: 0;
    background-image: url('/assets/imagery/kitchen-renovation-hero.jpg');
    background-size: cover;
    background-position: center;
    filter: brightness(0.3);
  }
  .thanks__bg-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(28, 81, 155, 0.92) 0%, rgba(20, 64, 122, 0.95) 50%, rgba(14, 46, 91, 0.94) 100%);
  }
  .thanks__bg-pattern { position: absolute; inset: 0; opacity: 0.45; }

  .thanks__container {
    position: relative;
    z-index: 1;
    max-width: 720px;
  }

  .thanks__card {
    text-align: center;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.12);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border-radius: var(--radius-xl);
    padding: clamp(2.5rem, 5vw, 4rem) clamp(1.5rem, 4vw, 3rem);
  }

  .thanks__check {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 72px;
    height: 72px;
    border-radius: 50%;
    background: rgba(252, 104, 54, 0.15);
    color: var(--gtw-orange);
    margin-bottom: 1.5rem;
  }

  .thanks__headline {
    color: var(--gtw-white);
    font-size: clamp(1.8rem, 4vw, 2.6rem);
    line-height: 1.2;
    margin: 1rem 0 0.85rem;
  }

  .thanks__lede {
    color: rgba(255, 255, 255, 0.88);
    font-size: clamp(1.1rem, 2vw, 1.3rem);
    line-height: 1.5;
    margin: 0 0 2rem;
    font-weight: 500;
  }

  .thanks__divider {
    width: 60px;
    height: 2px;
    background: var(--gtw-orange);
    margin: 0 auto 2rem;
    border-radius: 2px;
  }

  .thanks__small {
    color: rgba(255, 255, 255, 0.7);
    font-size: 0.95rem;
    line-height: 1.65;
    max-width: 480px;
    margin: 0 auto 2.5rem;
  }

  .thanks__actions {
    display: flex;
    justify-content: center;
    gap: 0.9rem;
    flex-wrap: wrap;
  }

  @media (max-width: 560px) {
    .thanks__actions { flex-direction: column-reverse; }
    .thanks__actions .btn { width: 100%; }
  }
</style>
